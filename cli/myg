#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir="$(cd "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)"
}
SCRIPT_DIR="$(resolve_path "$0")"
source "$SCRIPT_DIR/../.env"

TOKEN_FILE="$SCRIPT_DIR/../.token"
BASE="https://script.google.com/macros/s/${DEPLOY_ID}/exec"

show_help() {
  cat <<'EOF'
myg - My Google Workspace CLI

Usage: myg <action> [key=value ...]

Actions:
  auth                          Authenticate via browser and save token
  spreadsheets [max=<N>]        List all spreadsheets (default: 20)
  spreadsheet id=<ID or URL>    List sheets in a spreadsheet
  sheet id=<ID or URL> name=<SHEET>  Get sheet data
  sheet create id=<ID or URL> name=<SHEET>  Create new sheet
  sheet write id=<ID or URL> name=<SHEET> [range=A1]  Write CSV data from stdin
  docs [max=<N>]                List all documents (default: 20)
  doc id=<ID or URL>            Get document content
  doc create name="TITLE"       Create new document (stdin for body)
  doc append id=<ID or URL>     Append text from stdin
  doc overwrite id=<ID or URL>  Overwrite with text from stdin
    ※ Add format=markdown to convert Markdown with styling
  mails [q=<QUERY>] [max=<N>]  List emails (default: inbox, 20)
  mail id=<MESSAGE_ID>          Get email content
  mail draft to=<ADDR> subject="..." (stdin for body)  Create draft
  mail draft id=<DRAFT_ID> to=<ADDR> subject="..." (stdin for body)  Update draft
  mail draft delete id=<DRAFT_ID>  Delete draft
  mail filters                    List Gmail filters
  mail filter create q="<QUERY>" label="<LABEL>"  Create filter
  mail filter delete id=<FILTER_ID>  Delete filter
  files [id=<FOLDER_ID>] [max=<N>]  List Drive files (default: root, 20)
  file id=<FILE_ID>               Download file content
  file upload folder=<FOLDER_ID> name=<NAME> file=<PATH>  Upload file
  file move id=<FILE_ID> folder=<FOLDER_ID>  Move file
  slides [max=<N>]                List all presentations (default: 20)
  slide id=<ID or URL>            Get all slide content
  slide id=<ID or URL> page=<N>   Get specific page content
  slide create name="TITLE"       Create new presentation
  slide addpage id=<ID or URL>    Add blank page
  slide addtext id=<ID or URL> page=<N> text="TEXT"  Add text box (or stdin)
  tasklists                     List task lists
  tasks id=<TASKLIST_ID>        List tasks in a task list
  task create id=<TASKLIST_ID> title="TITLE" [due=YYYY-MM-DD] [notes="..."]  Create task
  task update id=<TASKLIST_ID> task=<TASK_ID> [title=...] [due=...] [notes="..."]  Update task
  task delete id=<TASKLIST_ID> task=<TASK_ID>  Delete task
  task done id=<TASKLIST_ID> task=<TASK_ID>  Complete task
  calendars                     List calendars
  events id=<CAL_ID> [from=YYYY-MM-DD] [to=YYYY-MM-DD]  List events (default: next 7 days)
  event create id=<CAL_ID> title="TITLE" start=<ISO> end=<ISO> [location=<LOC>]  Create event
    ※ id=self or omit id to use your default calendar

Examples:
  myg auth
  myg spreadsheets
  myg spreadsheet id=1abc...xyz
  myg sheet id=1abc...xyz "name=Sheet1"
  myg sheet create id=1abc...xyz "name=NewSheet"
  echo "A,B,C" | myg sheet write id=1abc...xyz "name=Sheet1" range=A1
  cat data.csv | myg sheet write id=1abc...xyz "name=Sheet1" range=B2
  myg docs
  myg doc id=1abc...xyz
  echo "text" | myg doc append id=1abc...xyz
  myg doc append id=1abc...xyz < memo.txt
  myg doc overwrite id=1abc...xyz < new.txt
  myg doc create name="My Note"
  echo "body" | myg doc create name="Meeting Notes"
  myg mails
  myg mails "q=from:someone@example.com" max=10
  myg mail id=18e1a2b3c4d5e6f7
  echo "本文" | myg mail draft to=someone@example.com subject="件名"
  echo "本文" | myg mail draft id=<DRAFT_ID> to=someone@example.com subject="件名"
  myg mail draft delete id=<DRAFT_ID>
  myg mail filters
  myg mail filter create q="from:someone@example.com" label="Work"
  myg mail filter delete id=<FILTER_ID>
  myg files
  myg files id=<FOLDER_ID> max=10
  myg file id=<FILE_ID>
  echo "content" | myg file upload folder=<FOLDER_ID> name="memo.txt"
  myg file upload folder=<FOLDER_ID> name="photo.png" file=./photo.png
  myg file move id=<FILE_ID> folder=<FOLDER_ID>
  myg slides
  myg slides max=10
  myg slide id=1abc...xyz
  myg slide id=1abc...xyz page=3
  myg slide create name="My Presentation"
  myg slide addpage id=1abc...xyz
  myg slide addtext id=1abc...xyz page=1 text="Hello World"
  echo "Long text" | myg slide addtext id=1abc...xyz page=1
  myg tasklists
  myg tasks id=<TASKLIST_ID>
  myg task create id=<TASKLIST_ID> title="Buy milk"
  myg task create id=<TASKLIST_ID> title="Report" due=2026-04-10
  myg task create id=<TASKLIST_ID> title="Report" due=2026-04-10 notes="Details here"
  myg task update id=<TASKLIST_ID> task=<TASK_ID> title="Updated title"
  myg task update id=<TASKLIST_ID> task=<TASK_ID> notes="Add description"
  myg task delete id=<TASKLIST_ID> task=<TASK_ID>
  myg task done id=<TASKLIST_ID> task=<TASK_ID>
  myg calendars
  myg events id=user@example.com from=2026-04-08 to=2026-04-15
  myg event create id=user@example.com title="Meeting" start=2026-04-10T10:00:00 end=2026-04-10T11:00:00
EOF
  exit 0
}

open_browser() {
  local url="$1"
  if command -v open &>/dev/null; then
    open "$url"
  elif command -v wslview &>/dev/null; then
    wslview "$url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    echo "Open this URL in your browser:" >&2
    echo "$url" >&2
  fi
}

action="${1:---help}"
shift 2>/dev/null || true

if [[ "$action" == "--help" || "$action" == "-h" || "$action" == "help" ]]; then
  show_help
fi

if [[ "$action" == "auth" ]]; then
  echo "Opening browser for authentication..." >&2
  open_browser "${BASE}?action=auth"
  echo -n "Paste token: " >&2
  read -r token
  echo "$token" > "$TOKEN_FILE"
  echo "Token saved." >&2
  exit 0
fi

if [[ -f "$TOKEN_FILE" ]]; then
  ACCESS_TOKEN=$(cat "$TOKEN_FILE")
elif [[ -f "$HOME/.clasprc.json" ]]; then
  ACCESS_TOKEN=$(jq -r '.token.access_token' "$HOME/.clasprc.json")
elif command -v gcloud &>/dev/null; then
  ACCESS_TOKEN=$(gcloud auth print-access-token 2>/dev/null)
else
  echo "No credentials. Run: myg auth" >&2
  exit 1
fi

curl_args=(-s -L -G -H "Authorization: Bearer ${ACCESS_TOKEN}" --data-urlencode "action=${action}")

# doc subcommands (create/append/overwrite) use POST + stdin
doc_subaction=""
if [[ "$action" == "doc" && $# -gt 0 ]]; then
  case "$1" in
    create|append|overwrite) doc_subaction="$1"; shift ;;
  esac
fi

# mail subcommands (draft) use POST
mail_subaction=""
if [[ "$action" == "mail" && $# -gt 0 ]]; then
  case "$1" in
    draft) mail_subaction="$1"; shift
           if [[ $# -gt 0 && "$1" == "delete" ]]; then
             mail_subaction="draft:delete"; shift
           fi ;;
    filters) mail_subaction="filters" ; shift ;;
    filter)  shift
             case "$1" in
               create|delete) mail_subaction="filter:$1"; shift ;;
             esac ;;
    label)   mail_subaction="label"; shift ;;

  esac
fi

# sheet write subcommand uses POST + stdin (TSV)
sheet_write=""
sheet_create=""
if [[ "$action" == "sheet" && $# -gt 0 ]]; then
  case "$1" in
    write)  sheet_write="1"; shift ;;
    create) sheet_create="1"; shift ;;
  esac
fi

# task subcommands (create/done) use POST
task_subaction=""
if [[ "$action" == "task" && $# -gt 0 ]]; then
  case "$1" in
    create|done|update|delete) task_subaction="$1"; shift ;;
  esac
fi

# file subcommands (upload/move) use POST
file_subaction=""
if [[ "$action" == "file" && $# -gt 0 ]]; then
  case "$1" in
    upload|move) file_subaction="$1"; shift ;;
  esac
fi

# slide subcommands (create/addpage/addtext) use POST
slide_subaction=""
if [[ "$action" == "slide" && $# -gt 0 ]]; then
  case "$1" in
    create|addpage|addtext|overwrite) slide_subaction="$1"; shift ;;
  esac
fi

# event subcommands (create) use POST
event_subaction=""
if [[ "$action" == "event" && $# -gt 0 ]]; then
  case "$1" in
    create) event_subaction="$1"; shift ;;
  esac
fi

if [[ -n "$slide_subaction" ]]; then
  sl_id=""
  sl_name=""
  sl_page=""
  sl_text=""
  sl_format=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     sl_id="${arg#id=}" ;;
      name=*)   sl_name="${arg#name=}" ;;
      page=*)   sl_page="${arg#page=}" ;;
      text=*)   sl_text="${arg#text=}" ;;
      format=*) sl_format="${arg#format=}" ;;
    esac
  done

  if [[ ("$slide_subaction" == "addtext" || "$slide_subaction" == "create" || "$slide_subaction" == "overwrite") && -z "$sl_text" && ! -t 0 ]]; then
    sl_text=$(cat)
  fi

  json_body=$(jq -n \
    --arg sub "$slide_subaction" \
    --arg id "$sl_id" \
    --arg name "$sl_name" \
    --arg page "$sl_page" \
    --arg text "$sl_text" \
    --arg format "$sl_format" \
    '{action: ("slide:" + $sub), id: $id, name: $name, page: $page, text: $text, format: $format}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$file_subaction" ]]; then
  fu_id=""
  fu_folder=""
  fu_name=""
  fu_file=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     fu_id="${arg#id=}" ;;
      folder=*) fu_folder="${arg#folder=}" ;;
      name=*)   fu_name="${arg#name=}" ;;
      file=*)   fu_file="${arg#file=}" ;;
    esac
  done

  if [[ "$file_subaction" == "upload" ]]; then
    if [[ -n "$fu_file" ]]; then
      fu_tmp=$(mktemp)
      base64 -w0 "$fu_file" > "$fu_tmp"
      fu_b64="true"
      fu_mime=$(file -b --mime-type "$fu_file")
    elif [[ ! -t 0 ]]; then
      fu_tmp=$(mktemp)
      cat > "$fu_tmp"
      fu_b64=""
      fu_mime=""
    else
      echo "Error: file= parameter or stdin required" >&2; exit 1
    fi

    fu_json=$(mktemp)
    jq -n \
      --rawfile data "$fu_tmp" \
      --arg folder "$fu_folder" \
      --arg name "$fu_name" \
      --arg isBase64 "$fu_b64" \
      --arg mimeType "$fu_mime" \
      '{action: "file:upload", folder: $folder, name: $name, data: $data, isBase64: $isBase64, mimeType: $mimeType}' > "$fu_json"
    rm -f "$fu_tmp"

    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -H "Content-Type: application/json" \
      -d @"$fu_json" "$BASE")
    rm -f "$fu_json"
  else
    json_body=$(jq -n \
      --arg id "$fu_id" \
      --arg folder "$fu_folder" \
      '{action: "file:move", id: $id, folder: $folder}')

    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "$json_body" "$BASE")
  fi
elif [[ "$mail_subaction" == "filters" ]]; then
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    "${BASE}?action=mail:filters")
elif [[ "$mail_subaction" == "label" ]]; then
  ml_query=""
  ml_label=""
  ml_skip_inbox=""
  for arg in "$@"; do
    case "$arg" in
      q=*)       ml_query="${arg#q=}" ;;
      label=*)   ml_label="${arg#label=}" ;;
      skipInbox) ml_skip_inbox="true" ;;
    esac
  done

  json_body=$(jq -n \
    --arg query "$ml_query" \
    --arg label "$ml_label" \
    --arg skipInbox "$ml_skip_inbox" \
    '{action: "mail:label", query: $query, label: $label, skipInbox: $skipInbox}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ "$mail_subaction" == "filter:create" || "$mail_subaction" == "filter:delete" ]]; then
  f_id=""
  f_query=""
  f_label=""
  f_skip_inbox=""
  for arg in "$@"; do
    case "$arg" in
      id=*)        f_id="${arg#id=}" ;;
      q=*)         f_query="${arg#q=}" ;;
      label=*)     f_label="${arg#label=}" ;;
      skipInbox)   f_skip_inbox="true" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$mail_subaction" \
    --arg id "$f_id" \
    --arg query "$f_query" \
    --arg label "$f_label" \
    --arg skipInbox "$f_skip_inbox" \
    '{action: ("mail:" + $sub), id: $id, query: $query, label: $label, skipInbox: $skipInbox}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$event_subaction" ]]; then
  ev_id=""
  ev_title=""
  ev_start=""
  ev_end=""
  ev_location=""
  for arg in "$@"; do
    case "$arg" in
      id=*)       ev_id="${arg#id=}" ;;
      title=*)    ev_title="${arg#title=}" ;;
      start=*)    ev_start="${arg#start=}" ;;
      end=*)      ev_end="${arg#end=}" ;;
      location=*) ev_location="${arg#location=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg id "$ev_id" \
    --arg title "$ev_title" \
    --arg start "$ev_start" \
    --arg end "$ev_end" \
    --arg location "$ev_location" \
    '{action: "event:create", id: $id, title: $title, start: $start, end: $end, location: $location}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ "$mail_subaction" == "draft:delete" ]]; then
  m_id=""
  for arg in "$@"; do
    case "$arg" in
      id=*) m_id="${arg#id=}" ;;
    esac
  done

  json_body=$(jq -n --arg id "$m_id" '{action: "mail:draft:delete", id: $id}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$mail_subaction" ]]; then
  m_to=""
  m_subject=""
  m_id=""
  for arg in "$@"; do
    case "$arg" in
      to=*)      m_to="${arg#to=}" ;;
      subject=*) m_subject="${arg#subject=}" ;;
      id=*)      m_id="${arg#id=}" ;;
    esac
  done

  m_body=""
  if [[ ! -t 0 ]]; then
    m_body=$(cat)
  fi

  json_body=$(jq -n \
    --arg id "$m_id" \
    --arg to "$m_to" \
    --arg subject "$m_subject" \
    --arg text "$m_body" \
    '{action: "mail:draft", id: $id, to: $to, subject: $subject, text: $text}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$task_subaction" ]]; then
  t_id=""
  t_title=""
  t_due=""
  t_task=""
  t_notes=""
  for arg in "$@"; do
    case "$arg" in
      id=*)    t_id="${arg#id=}" ;;
      title=*) t_title="${arg#title=}" ;;
      due=*)   t_due="${arg#due=}" ;;
      task=*)  t_task="${arg#task=}" ;;
      notes=*) t_notes="${arg#notes=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$task_subaction" \
    --arg id "$t_id" \
    --arg title "$t_title" \
    --arg due "$t_due" \
    --arg task "$t_task" \
    --arg notes "$t_notes" \
    '{action: ("task:" + $sub), id: $id, title: $title, due: $due, task: $task, notes: $notes}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$sheet_create" ]]; then
  sc_id=""
  sc_name=""
  for arg in "$@"; do
    case "$arg" in
      id=*)   sc_id="${arg#id=}" ;;
      name=*) sc_name="${arg#name=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg id "$sc_id" \
    --arg name "$sc_name" \
    '{action: "sheet:create", id: $id, name: $name}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$sheet_write" ]]; then
  sw_id=""
  sw_name=""
  sw_range="A1"
  for arg in "$@"; do
    case "$arg" in
      id=*)    sw_id="${arg#id=}" ;;
      name=*)  sw_name="${arg#name=}" ;;
      range=*) sw_range="${arg#range=}" ;;
    esac
  done

  stdin_text=""
  if [[ ! -t 0 ]]; then
    stdin_text=$(cat)
  fi
  if [[ -z "$stdin_text" ]]; then
    echo "Error: No data provided via stdin" >&2
    exit 1
  fi

  json_body=$(jq -n \
    --arg id "$sw_id" \
    --arg name "$sw_name" \
    --arg range "$sw_range" \
    --arg text "$stdin_text" \
    '{action: "sheet:write", id: $id, name: $name, range: $range, text: $text}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$doc_subaction" ]]; then
  doc_id=""
  doc_name=""
  doc_format=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     doc_id="${arg#id=}" ;;
      name=*)   doc_name="${arg#name=}" ;;
      format=*) doc_format="${arg#format=}" ;;
    esac
  done

  stdin_text=""
  if [[ ! -t 0 ]]; then
    stdin_text=$(cat)
  fi

  json_body=$(jq -n \
    --arg sub "$doc_subaction" \
    --arg id "$doc_id" \
    --arg name "$doc_name" \
    --arg text "$stdin_text" \
    --arg format "$doc_format" \
    '{action: ("doc:" + $sub), id: $id, name: $name, text: $text, format: $format}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
else
  for arg in "$@"; do
    curl_args+=(--data-urlencode "$arg")
  done
  response=$(curl "${curl_args[@]}" "$BASE")
fi

if echo "$response" | grep -qi '<html'; then
  echo "Error: Received HTML response. Your token may have expired." >&2
  echo "Run: myg auth" >&2
  exit 1
fi

echo "$response" | jq . 2>/dev/null || echo "$response"
