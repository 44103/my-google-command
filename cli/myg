  t_task=""
  t_notes=""
  t_parent=""
  for arg in "$@"; do
    case "$arg" in
      id=*)    t_id="${arg#id=}" ;;
      title=*) t_title="${arg#title=}" ;;
      due=*)   t_due="${arg#due=}" ;;
      task=*)  t_task="${arg#task=}" ;;
      notes=*) t_notes="${arg#notes=}" ;;
      parent=*) t_parent="${arg#parent=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$task_subaction" \
    --arg id "$t_id" \
    --arg title "$t_title" \
    --arg due "$t_due" \
    --arg task "$t_task" \
