  myg task create id=<TASKLIST_ID> title="Report" due=2026-04-10 notes="Details here"
  myg task create id=<TASKLIST_ID> title="Subtask" parent=<TASK_ID>
  myg task update id=<TASKLIST_ID> task=<TASK_ID> title="Updated title"
  myg task update id=<TASKLIST_ID> task=<TASK_ID> notes="Add description"
  myg task delete id=<TASKLIST_ID> task=<TASK_ID>
  myg task done id=<TASKLIST_ID> task=<TASK_ID>
  myg calendars
  myg events id=user@example.com from=2026-04-08 to=2026-04-15
  myg event create id=user@example.com title="Meeting" start=2026-04-10T10:00:00 end=2026-04-10T11:00:00
EOF
  exit 0
}

open_browser() {
  local url="$1"
  if command -v open &>/dev/null; then
    open "$url"
  elif command -v wslview &>/dev/null; then
    wslview "$url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    echo "Open this URL in your browser:" >&2
    echo "$url" >&2
  fi
}

action="${1:---help}"
shift 2>/dev/null || true

if [[ "$action" == "--help" || "$action" == "-h" || "$action" == "help" ]]; then
  show_help
fi

if [[ "$action" == "auth" ]]; then
  # Auto-update check
  repo_dir="$(cd "$SCRIPT_DIR/.." && pwd)"
  if git -C "$repo_dir" rev-parse --is-inside-work-tree &>/dev/null; then
    old_rev=$(git -C "$repo_dir" rev-parse HEAD 2>/dev/null)
    git -C "$repo_dir" fetch --quiet 2>/dev/null
    new_rev=$(git -C "$repo_dir" rev-parse origin/main 2>/dev/null)
    if [[ -n "$old_rev" && -n "$new_rev" && "$old_rev" != "$new_rev" ]]; then
      git -C "$repo_dir" reset --hard origin/main --quiet 2>/dev/null
      count=$(git -C "$repo_dir" rev-list "$old_rev..$new_rev" --count 2>/dev/null || echo "?")
      echo "Updated myg ($count new commit(s)):" >&2
      git -C "$repo_dir" log --oneline "$old_rev..$new_rev" 2>/dev/null | sed 's/^/  - /' >&2
      echo "" >&2
    fi
  fi

  echo "Opening browser for authentication..." >&2
  open_browser "${BASE}?action=auth"
  echo -n "Paste token: " >&2
  read -r token
  echo "$token" > "$TOKEN_FILE"
  echo "Token saved." >&2
  exit 0
fi

if [[ -f "$TOKEN_FILE" ]]; then
  ACCESS_TOKEN=$(cat "$TOKEN_FILE")
elif [[ -f "$HOME/.clasprc.json" ]]; then
  ACCESS_TOKEN=$(jq -r '.token.access_token' "$HOME/.clasprc.json")
elif command -v gcloud &>/dev/null; then
  ACCESS_TOKEN=$(gcloud auth print-access-token 2>/dev/null)
else
  echo "No credentials. Run: myg auth" >&2
  exit 1
fi

curl_args=(-s -L -G -H "Authorization: Bearer ${ACCESS_TOKEN}" --data-urlencode "action=${action}")

# doc subcommands (create/append/overwrite) use POST + stdin
doc_subaction=""
if [[ "$action" == "doc" && $# -gt 0 ]]; then
  case "$1" in
    create|append|overwrite|addtab|renametab|movetab) doc_subaction="$1"; shift ;;
    tabs) doc_subaction="tabs"; shift ;;
  esac
fi

# mail subcommands (draft) use POST
mail_subaction=""
if [[ "$action" == "mail" && $# -gt 0 ]]; then
  case "$1" in
    draft) mail_subaction="$1"; shift
           if [[ $# -gt 0 && "$1" == "delete" ]]; then
             mail_subaction="draft:delete"; shift
           fi ;;
    filters) mail_subaction="filters" ; shift ;;
    labels)  mail_subaction="labels" ; shift ;;
    filter)  shift
             case "$1" in
               create|delete) mail_subaction="filter:$1"; shift ;;
             esac ;;
    label)   mail_subaction="label"; shift ;;

  esac
fi

# sheet write subcommand uses POST + stdin (TSV)
sheet_write=""
sheet_create=""
spreadsheet_create=""
if [[ "$action" == "sheet" && $# -gt 0 ]]; then
  case "$1" in
    write)  sheet_write="1"; shift ;;
    create) sheet_create="1"; shift ;;
  esac
fi
if [[ "$action" == "spreadsheet" && $# -gt 0 ]]; then
  case "$1" in
    create) spreadsheet_create="1"; shift ;;
  esac
fi

# task subcommands (create/done) use POST
task_subaction=""
if [[ "$action" == "task" && $# -gt 0 ]]; then
  case "$1" in
    create|done|update|delete) task_subaction="$1"; shift ;;
  esac
fi

# tasklist subcommands use POST
tasklist_subaction=""
if [[ "$action" == "tasklist" && $# -gt 0 ]]; then
  case "$1" in
    create|update|delete) tasklist_subaction="$1"; shift ;;
  esac
fi

# file subcommands (upload/move) use POST
file_subaction=""
if [[ "$action" == "file" && $# -gt 0 ]]; then
  case "$1" in
    upload|move|copy|history|diff|rename|shortcut) file_subaction="$1"; shift ;;
  esac
fi

# slide subcommands (create/addpage/addtext) use POST
slide_subaction=""
if [[ "$action" == "slide" && $# -gt 0 ]]; then
  case "$1" in
    create|addpage|addtext|overwrite) slide_subaction="$1"; shift ;;
  esac
fi

# form subcommands use POST or special GET
form_subaction=""
if [[ "$action" == "form" && $# -gt 0 ]]; then
  case "$1" in
    create|additem) form_subaction="$1"; shift ;;
    responses)      form_subaction="responses"; shift ;;
  esac
fi

# contacts subcommands
contacts_subaction=""
if [[ "$action" == "contacts" && $# -gt 0 ]]; then
  case "$1" in
    search) contacts_subaction="search"; shift ;;
  esac
fi

# files subcommands
files_subaction=""
if [[ "$action" == "files" && $# -gt 0 ]]; then
  case "$1" in
    search) files_subaction="search"; shift ;;
  esac
fi

# tasks subcommands
tasks_subaction=""
if [[ "$action" == "tasks" && $# -gt 0 ]]; then
  case "$1" in
    completed) tasks_subaction="completed"; shift ;;
  esac
fi

# event subcommands (create) use POST
event_subaction=""
if [[ "$action" == "event" && $# -gt 0 ]]; then
  case "$1" in
    create|freebusy|update|delete) event_subaction="$1"; shift ;;
  esac
fi

if [[ -n "$tasks_subaction" ]]; then
  tc_id=""
  for arg in "$@"; do
    case "$arg" in
      id=*) tc_id="${arg#id=}" ;;
    esac
  done
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -G --data-urlencode "action=tasks:completed" --data-urlencode "id=${tc_id}" "$BASE")
elif [[ -n "$files_subaction" ]]; then
  fs_q=""
  fs_max=""
  for arg in "$@"; do
    case "$arg" in
      q=*)   fs_q="${arg#q=}" ;;
      max=*) fs_max="${arg#max=}" ;;
    esac
  done
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -G --data-urlencode "action=files:search" --data-urlencode "q=${fs_q}" --data-urlencode "max=${fs_max:-20}" "$BASE")
elif [[ -n "$contacts_subaction" ]]; then
  c_q=""
  c_max=""
  for arg in "$@"; do
    case "$arg" in
      q=*)   c_q="${arg#q=}" ;;
      max=*) c_max="${arg#max=}" ;;
    esac
  done
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -G --data-urlencode "action=contacts:search" --data-urlencode "q=${c_q}" --data-urlencode "max=${c_max:-20}" "$BASE")
elif [[ -n "$form_subaction" ]]; then
  fm_id=""
  fm_name=""
  fm_desc=""
  fm_type=""
  fm_title=""
  fm_choices=""
  fm_required=""
  fm_low=""
  fm_high=""
  fm_lowLabel=""
  fm_highLabel=""
  for arg in "$@"; do
    case "$arg" in
      id=*)        fm_id="${arg#id=}" ;;
      name=*)      fm_name="${arg#name=}" ;;
      description=*) fm_desc="${arg#description=}" ;;
      type=*)      fm_type="${arg#type=}" ;;
      title=*)     fm_title="${arg#title=}" ;;
      choices=*)   fm_choices="${arg#choices=}" ;;
      required)    fm_required="true" ;;
      low=*)       fm_low="${arg#low=}" ;;
      high=*)      fm_high="${arg#high=}" ;;
      lowLabel=*)  fm_lowLabel="${arg#lowLabel=}" ;;
      highLabel=*) fm_highLabel="${arg#highLabel=}" ;;
    esac
  done

  if [[ "$form_subaction" == "responses" ]]; then
    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      "${BASE}?action=form:responses&id=${fm_id}")
  else
    json_body=$(jq -n \
      --arg sub "$form_subaction" \
      --arg id "$fm_id" \
      --arg name "$fm_name" \
      --arg description "$fm_desc" \
      --arg type "$fm_type" \
      --arg title "$fm_title" \
      --arg choices "$fm_choices" \
      --arg required "$fm_required" \
      --arg low "$fm_low" \
      --arg high "$fm_high" \
      --arg lowLabel "$fm_lowLabel" \
      --arg highLabel "$fm_highLabel" \
      '{action: ("form:" + $sub), id: $id, name: $name, description: $description, type: $type, title: $title, choices: $choices, required: $required, low: $low, high: $high, lowLabel: $lowLabel, highLabel: $highLabel}')

    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "$json_body" "$BASE")
  fi
elif [[ -n "$slide_subaction" ]]; then
  sl_id=""
  sl_name=""
  sl_page=""
  sl_text=""
  sl_format=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     sl_id="${arg#id=}" ;;
      name=*)   sl_name="${arg#name=}" ;;
      page=*)   sl_page="${arg#page=}" ;;
      text=*)   sl_text="${arg#text=}" ;;
      format=*) sl_format="${arg#format=}" ;;
    esac
  done

  if [[ ("$slide_subaction" == "addtext" || "$slide_subaction" == "create" || "$slide_subaction" == "overwrite") && -z "$sl_text" && ! -t 0 ]]; then
    sl_text=$(cat)
  fi

  json_body=$(jq -n \
    --arg sub "$slide_subaction" \
    --arg id "$sl_id" \
    --arg name "$sl_name" \
    --arg page "$sl_page" \
    --arg text "$sl_text" \
    --arg format "$sl_format" \
    '{action: ("slide:" + $sub), id: $id, name: $name, page: $page, text: $text, format: $format}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$file_subaction" ]]; then
  fu_id=""
  fu_folder=""
  fu_name=""
  fu_file=""
  fu_max=""
  fu_rev1=""
  fu_rev2=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     fu_id="${arg#id=}" ;;
      folder=*) fu_folder="${arg#folder=}" ;;
      name=*)   fu_name="${arg#name=}" ;;
      file=*)   fu_file="${arg#file=}" ;;
      max=*)    fu_max="${arg#max=}" ;;
      rev1=*)   fu_rev1="${arg#rev1=}" ;;
      rev2=*)   fu_rev2="${arg#rev2=}" ;;
    esac
  done

  if [[ "$file_subaction" == "diff" ]]; then
    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -G --data-urlencode "action=file:revision" --data-urlencode "id=${fu_id}" \
      --data-urlencode "rev1=${fu_rev1}" --data-urlencode "rev2=${fu_rev2}" "$BASE")
  elif [[ "$file_subaction" == "history" ]]; then
    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -G --data-urlencode "action=file:history" --data-urlencode "id=${fu_id}" --data-urlencode "max=${fu_max:-20}" "$BASE")
  elif [[ "$file_subaction" == "upload" ]]; then
    if [[ -n "$fu_file" ]]; then
      fu_tmp=$(mktemp)
      base64 -w0 "$fu_file" > "$fu_tmp"
      fu_b64="true"
      fu_mime=$(file -b --mime-type "$fu_file")
    elif [[ ! -t 0 ]]; then
      fu_tmp=$(mktemp)
      cat > "$fu_tmp"
      fu_b64=""
      fu_mime=""
    else
      echo "Error: file= parameter or stdin required" >&2; exit 1
    fi

    fu_json=$(mktemp)
    jq -n \
      --rawfile data "$fu_tmp" \
      --arg folder "$fu_folder" \
      --arg name "$fu_name" \
      --arg isBase64 "$fu_b64" \
      --arg mimeType "$fu_mime" \
      '{action: "file:upload", folder: $folder, name: $name, data: $data, isBase64: $isBase64, mimeType: $mimeType}' > "$fu_json"
    rm -f "$fu_tmp"

    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -H "Content-Type: application/json" \
      -d @"$fu_json" "$BASE")
    rm -f "$fu_json"
  else
    json_body=$(jq -n \
      --arg action "file:$file_subaction" \
      --arg id "$fu_id" \
      --arg folder "$fu_folder" \
      --arg name "$fu_name" \
      '{action: $action, id: $id, folder: $folder, name: $name}')

    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "$json_body" "$BASE")
  fi
elif [[ "$mail_subaction" == "filters" ]]; then
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    "${BASE}?action=mail:filters")
elif [[ "$mail_subaction" == "labels" ]]; then
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    "${BASE}?action=mail:labels")
elif [[ "$mail_subaction" == "label" ]]; then
  ml_query=""
  ml_label=""
  ml_skip_inbox=""
  for arg in "$@"; do
    case "$arg" in
      q=*)       ml_query="${arg#q=}" ;;
      label=*)   ml_label="${arg#label=}" ;;
      skipInbox) ml_skip_inbox="true" ;;
    esac
  done

  json_body=$(jq -n \
    --arg query "$ml_query" \
    --arg label "$ml_label" \
    --arg skipInbox "$ml_skip_inbox" \
    '{action: "mail:label", query: $query, label: $label, skipInbox: $skipInbox}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ "$mail_subaction" == "filter:create" || "$mail_subaction" == "filter:delete" ]]; then
  f_id=""
  f_query=""
  f_label=""
  f_skip_inbox=""
  for arg in "$@"; do
    case "$arg" in
      id=*)        f_id="${arg#id=}" ;;
      q=*)         f_query="${arg#q=}" ;;
      label=*)     f_label="${arg#label=}" ;;
      skipInbox)   f_skip_inbox="true" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$mail_subaction" \
    --arg id "$f_id" \
    --arg query "$f_query" \
    --arg label "$f_label" \
    --arg skipInbox "$f_skip_inbox" \
    '{action: ("mail:" + $sub), id: $id, query: $query, label: $label, skipInbox: $skipInbox}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ "$event_subaction" == "freebusy" ]]; then
  ev_emails=""
  ev_from=""
  ev_to=""
  ev_duration=""
  for arg in "$@"; do
    case "$arg" in
      emails=*)   ev_emails="${arg#emails=}" ;;
      from=*)     ev_from="${arg#from=}" ;;
      to=*)       ev_to="${arg#to=}" ;;
      duration=*) ev_duration="${arg#duration=}" ;;
    esac
  done
  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -G --data-urlencode "action=event:freebusy" --data-urlencode "emails=${ev_emails}" \
    --data-urlencode "from=${ev_from}" --data-urlencode "to=${ev_to}" \
    --data-urlencode "duration=${ev_duration}" "$BASE")
elif [[ -n "$event_subaction" ]]; then
  ev_id=""
  ev_title=""
  ev_start=""
  ev_end=""
  ev_location=""
  ev_event=""
  for arg in "$@"; do
    case "$arg" in
      id=*)       ev_id="${arg#id=}" ;;
      title=*)    ev_title="${arg#title=}" ;;
      start=*)    ev_start="${arg#start=}" ;;
      end=*)      ev_end="${arg#end=}" ;;
      location=*) ev_location="${arg#location=}" ;;
      event=*)    ev_event="${arg#event=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$event_subaction" \
    --arg id "$ev_id" \
    --arg event "$ev_event" \
    --arg title "$ev_title" \
    --arg start "$ev_start" \
    --arg end "$ev_end" \
    --arg location "$ev_location" \
    '{action: ("event:" + $sub), id: $id, event: $event, title: $title, start: $start, end: $end, location: $location}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ "$mail_subaction" == "draft:delete" ]]; then
  m_id=""
  for arg in "$@"; do
    case "$arg" in
      id=*) m_id="${arg#id=}" ;;
    esac
  done

  json_body=$(jq -n --arg id "$m_id" '{action: "mail:draft:delete", id: $id}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$mail_subaction" ]]; then
  m_to=""
  m_subject=""
  m_id=""
  for arg in "$@"; do
    case "$arg" in
      to=*)      m_to="${arg#to=}" ;;
      subject=*) m_subject="${arg#subject=}" ;;
      id=*)      m_id="${arg#id=}" ;;
    esac
  done

  m_body=""
  if [[ ! -t 0 ]]; then
    m_body=$(cat)
  fi

  json_body=$(jq -n \
    --arg id "$m_id" \
    --arg to "$m_to" \
    --arg subject "$m_subject" \
    --arg text "$m_body" \
    '{action: "mail:draft", id: $id, to: $to, subject: $subject, text: $text}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$task_subaction" ]]; then
