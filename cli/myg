    --arg parent "$t_parent" \
    '{action: ("task:" + $sub), id: $id, title: $title, due: $due, task: $task, notes: $notes, parent: $parent}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$tasklist_subaction" ]]; then
  tl_id=""
  tl_title=""
  for arg in "$@"; do
    case "$arg" in
      id=*)    tl_id="${arg#id=}" ;;
      title=*) tl_title="${arg#title=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$tasklist_subaction" \
    --arg id "$tl_id" \
    --arg title "$tl_title" \
    '{action: ("tasklist:" + $sub), id: $id, title: $title}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$spreadsheet_create" ]]; then
  sp_name=""
  for arg in "$@"; do
    case "$arg" in
      name=*) sp_name="${arg#name=}" ;;
    esac
  done

  json_body=$(jq -n --arg name "$sp_name" '{action: "spreadsheet:create", name: $name}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$sheet_create" ]]; then
  sc_id=""
  sc_name=""
  for arg in "$@"; do
    case "$arg" in
      id=*)   sc_id="${arg#id=}" ;;
      name=*) sc_name="${arg#name=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg id "$sc_id" \
    --arg name "$sc_name" \
    '{action: "sheet:create", id: $id, name: $name}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$sheet_write" ]]; then
  sw_id=""
  sw_name=""
  sw_range="A1"
  for arg in "$@"; do
    case "$arg" in
      id=*)    sw_id="${arg#id=}" ;;
      name=*)  sw_name="${arg#name=}" ;;
      range=*) sw_range="${arg#range=}" ;;
    esac
  done

  stdin_text=""
  if [[ ! -t 0 ]]; then
    stdin_text=$(cat)
  fi
  if [[ -z "$stdin_text" ]]; then
    echo "Error: No data provided via stdin" >&2
    exit 1
  fi

  json_body=$(jq -n \
    --arg id "$sw_id" \
    --arg name "$sw_name" \
    --arg range "$sw_range" \
    --arg text "$stdin_text" \
    '{action: "sheet:write", id: $id, name: $name, range: $range, text: $text}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$doc_subaction" ]]; then
  doc_id=""
  doc_name=""
  doc_format=""
  doc_tab=""
  doc_index=""
  doc_parent=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     doc_id="${arg#id=}" ;;
      name=*)   doc_name="${arg#name=}" ;;
      format=*) doc_format="${arg#format=}" ;;
      tab=*)    doc_tab="${arg#tab=}" ;;
      index=*)  doc_index="${arg#index=}" ;;
      parent=*) doc_parent="${arg#parent=}" ;;
    esac
  done

  if [[ "$doc_subaction" == "tabs" ]]; then
    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -G --data-urlencode "action=doc:tabs" --data-urlencode "id=${doc_id}" "$BASE")
  else
    stdin_text=""
    if [[ ! -t 0 ]]; then
      stdin_text=$(cat)
    fi

    json_body=$(jq -n \
      --arg sub "$doc_subaction" \
      --arg id "$doc_id" \
      --arg name "$doc_name" \
      --arg text "$stdin_text" \
      --arg format "$doc_format" \
      --arg tab "$doc_tab" \
      --arg index "$doc_index" \
      --arg parent "$doc_parent" \
      '{action: ("doc:" + $sub), id: $id, name: $name, text: $text, format: $format, tab: $tab, index: $index, parent: $parent}')

    response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
      -H "Content-Type: application/json" \
      -d "$json_body" "$BASE")
  fi
else
  for arg in "$@"; do
    curl_args+=(--data-urlencode "$arg")
  done
  response=$(curl "${curl_args[@]}" "$BASE")
fi

if echo "$response" | grep -qi '<html'; then
  echo "Error: Received HTML response. Your token may have expired." >&2
  echo "Run: myg auth" >&2
  exit 1
fi

echo "$response" | jq . 2>/dev/null || echo "$response"
