#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local target="$1"
  while [ -L "$target" ]; do
    local dir="$(cd "$(dirname "$target")" && pwd)"
    target="$(readlink "$target")"
    [[ "$target" != /* ]] && target="$dir/$target"
  done
  echo "$(cd "$(dirname "$target")" && pwd)"
}
SCRIPT_DIR="$(resolve_path "$0")"
source "$SCRIPT_DIR/../.env"

TOKEN_FILE="$SCRIPT_DIR/../.token"
BASE="https://script.google.com/macros/s/${DEPLOY_ID}/exec"

show_help() {
  cat <<'EOF'
myg - My Google Workspace CLI

Usage: myg <action> [key=value ...]

Actions:
  auth                          Authenticate via browser and save token
  spreadsheets [max=<N>]        List all spreadsheets (default: 20)
  spreadsheet id=<ID or URL>    List sheets in a spreadsheet
  sheet id=<ID or URL> name=<SHEET>  Get sheet data
  sheet write id=<ID or URL> name=<SHEET> [range=A1]  Write CSV data from stdin
  docs [max=<N>]                List all documents (default: 20)
  doc id=<ID or URL>            Get document content
  doc create name="TITLE"       Create new document (stdin for body)
  doc append id=<ID or URL>     Append text from stdin
  doc overwrite id=<ID or URL>  Overwrite with text from stdin
    ※ Add format=markdown to convert Markdown with styling
  mails [q=<QUERY>] [max=<N>]  List emails (default: inbox, 20)
  mail id=<MESSAGE_ID>          Get email content
  tasklists                     List task lists
  tasks id=<TASKLIST_ID>        List tasks in a task list
  task create id=<TASKLIST_ID> title="TITLE" [due=YYYY-MM-DD]  Create task
  task done id=<TASKLIST_ID> task=<TASK_ID>  Complete task
  calendars                     List calendars
  events id=<CAL_ID> [from=YYYY-MM-DD] [to=YYYY-MM-DD]  List events (default: next 7 days)
  event create id=<CAL_ID> title="TITLE" start=<ISO> end=<ISO> [location=<LOC>]  Create event
    ※ id=self or omit id to use your default calendar

Examples:
  myg auth
  myg spreadsheets
  myg spreadsheet id=1abc...xyz
  myg sheet id=1abc...xyz "name=Sheet1"
  echo "A,B,C" | myg sheet write id=1abc...xyz "name=Sheet1" range=A1
  cat data.csv | myg sheet write id=1abc...xyz "name=Sheet1" range=B2
  myg docs
  myg doc id=1abc...xyz
  echo "text" | myg doc append id=1abc...xyz
  myg doc append id=1abc...xyz < memo.txt
  myg doc overwrite id=1abc...xyz < new.txt
  myg doc create name="My Note"
  echo "body" | myg doc create name="Meeting Notes"
  myg mails
  myg mails "q=from:someone@example.com" max=10
  myg mail id=18e1a2b3c4d5e6f7
  myg tasklists
  myg tasks id=<TASKLIST_ID>
  myg task create id=<TASKLIST_ID> title="Buy milk"
  myg task create id=<TASKLIST_ID> title="Report" due=2026-04-10
  myg task done id=<TASKLIST_ID> task=<TASK_ID>
  myg calendars
  myg events id=user@example.com from=2026-04-08 to=2026-04-15
  myg event create id=user@example.com title="Meeting" start=2026-04-10T10:00:00 end=2026-04-10T11:00:00
EOF
  exit 0
}

open_browser() {
  local url="$1"
  if command -v open &>/dev/null; then
    open "$url"
  elif command -v wslview &>/dev/null; then
    wslview "$url"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  else
    echo "Open this URL in your browser:" >&2
    echo "$url" >&2
  fi
}

action="${1:---help}"
shift 2>/dev/null || true

if [[ "$action" == "--help" || "$action" == "-h" || "$action" == "help" ]]; then
  show_help
fi

if [[ "$action" == "auth" ]]; then
  echo "Opening browser for authentication..." >&2
  open_browser "${BASE}?action=auth"
  echo -n "Paste token: " >&2
  read -r token
  echo "$token" > "$TOKEN_FILE"
  echo "Token saved." >&2
  exit 0
fi

if [[ -f "$TOKEN_FILE" ]]; then
  ACCESS_TOKEN=$(cat "$TOKEN_FILE")
elif [[ -f "$HOME/.clasprc.json" ]]; then
  ACCESS_TOKEN=$(jq -r '.token.access_token' "$HOME/.clasprc.json")
elif command -v gcloud &>/dev/null; then
  ACCESS_TOKEN=$(gcloud auth print-access-token 2>/dev/null)
else
  echo "No credentials. Run: myg auth" >&2
  exit 1
fi

curl_args=(-s -L -G -H "Authorization: Bearer ${ACCESS_TOKEN}" --data-urlencode "action=${action}")

# doc subcommands (create/append/overwrite) use POST + stdin
doc_subaction=""
if [[ "$action" == "doc" && $# -gt 0 ]]; then
  case "$1" in
    create|append|overwrite) doc_subaction="$1"; shift ;;
  esac
fi

# sheet write subcommand uses POST + stdin (TSV)
sheet_write=""
if [[ "$action" == "sheet" && $# -gt 0 && "$1" == "write" ]]; then
  sheet_write="1"; shift
fi

# task subcommands (create/done) use POST
task_subaction=""
if [[ "$action" == "task" && $# -gt 0 ]]; then
  case "$1" in
    create|done) task_subaction="$1"; shift ;;
  esac
fi

# event subcommands (create) use POST
event_subaction=""
if [[ "$action" == "event" && $# -gt 0 ]]; then
  case "$1" in
    create) event_subaction="$1"; shift ;;
  esac
fi

if [[ -n "$event_subaction" ]]; then
  ev_id=""
  ev_title=""
  ev_start=""
  ev_end=""
  ev_location=""
  for arg in "$@"; do
    case "$arg" in
      id=*)       ev_id="${arg#id=}" ;;
      title=*)    ev_title="${arg#title=}" ;;
      start=*)    ev_start="${arg#start=}" ;;
      end=*)      ev_end="${arg#end=}" ;;
      location=*) ev_location="${arg#location=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg id "$ev_id" \
    --arg title "$ev_title" \
    --arg start "$ev_start" \
    --arg end "$ev_end" \
    --arg location "$ev_location" \
    '{action: "event:create", id: $id, title: $title, start: $start, end: $end, location: $location}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$task_subaction" ]]; then
  t_id=""
  t_title=""
  t_due=""
  t_task=""
  for arg in "$@"; do
    case "$arg" in
      id=*)    t_id="${arg#id=}" ;;
      title=*) t_title="${arg#title=}" ;;
      due=*)   t_due="${arg#due=}" ;;
      task=*)  t_task="${arg#task=}" ;;
    esac
  done

  json_body=$(jq -n \
    --arg sub "$task_subaction" \
    --arg id "$t_id" \
    --arg title "$t_title" \
    --arg due "$t_due" \
    --arg task "$t_task" \
    '{action: ("task:" + $sub), id: $id, title: $title, due: $due, task: $task}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$sheet_write" ]]; then
  sw_id=""
  sw_name=""
  sw_range="A1"
  for arg in "$@"; do
    case "$arg" in
      id=*)    sw_id="${arg#id=}" ;;
      name=*)  sw_name="${arg#name=}" ;;
      range=*) sw_range="${arg#range=}" ;;
    esac
  done

  stdin_text=""
  if [[ ! -t 0 ]]; then
    stdin_text=$(cat)
  fi
  if [[ -z "$stdin_text" ]]; then
    echo "Error: No data provided via stdin" >&2
    exit 1
  fi

  json_body=$(jq -n \
    --arg id "$sw_id" \
    --arg name "$sw_name" \
    --arg range "$sw_range" \
    --arg text "$stdin_text" \
    '{action: "sheet:write", id: $id, name: $name, range: $range, text: $text}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
elif [[ -n "$doc_subaction" ]]; then
  doc_id=""
  doc_name=""
  doc_format=""
  for arg in "$@"; do
    case "$arg" in
      id=*)     doc_id="${arg#id=}" ;;
      name=*)   doc_name="${arg#name=}" ;;
      format=*) doc_format="${arg#format=}" ;;
    esac
  done

  stdin_text=""
  if [[ ! -t 0 ]]; then
    stdin_text=$(cat)
  fi

  json_body=$(jq -n \
    --arg sub "$doc_subaction" \
    --arg id "$doc_id" \
    --arg name "$doc_name" \
    --arg text "$stdin_text" \
    --arg format "$doc_format" \
    '{action: ("doc:" + $sub), id: $id, name: $name, text: $text, format: $format}')

  response=$(curl -s -L -H "Authorization: Bearer ${ACCESS_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "$json_body" "$BASE")
else
  for arg in "$@"; do
    curl_args+=(--data-urlencode "$arg")
  done
  response=$(curl "${curl_args[@]}" "$BASE")
fi

if echo "$response" | grep -qi '<html'; then
  echo "Error: Received HTML response. Your token may have expired." >&2
  echo "Run: myg auth" >&2
  exit 1
fi

echo "$response" | jq . 2>/dev/null || echo "$response"
